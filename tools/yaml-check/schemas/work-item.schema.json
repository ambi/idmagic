{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://regenerative-architecture/schemas/work-item.json",
  "title": "Work Item",
  "description": "WORK_ITEM_FORMAT.md を正本とするワークアイテムのスキーマ（同文書からの派生物）。work-items/<id>.md に置き、完了時は completion を同じファイルに追記する。",
  "type": "object",
  "required": [
    "id",
    "title",
    "created_at",
    "authors",
    "status",
    "motivation",
    "scope",
    "out_of_scope",
    "verification",
    "risk",
    "risk_notes"
  ],
  "allOf": [
    {
      "if": {
        "properties": { "status": { "enum": ["pending", "in_progress"] } },
        "required": ["status"]
      },
      "then": { "required": ["depends_on"] }
    },
    {
      "if": {
        "properties": { "status": { "enum": ["completed", "cancelled"] } },
        "required": ["status"]
      },
      "then": { "required": ["completion"] }
    },
    {
      "if": {
        "properties": { "change_kind": { "enum": ["feature", "bugfix", "operations"] } },
        "required": ["change_kind"]
      },
      "then": { "required": ["initial_context", "affected_spec"] }
    },
    {
      "if": {
        "properties": { "change_kind": { "enum": ["refactor", "docs", "tooling", "maintenance"] } },
        "required": ["change_kind"]
      },
      "then": {
        "oneOf": [{ "required": ["affected_spec"] }, { "required": ["spec_impact"] }]
      }
    }
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "ファイル名 (拡張子を除く) から導出される安定識別子。frontmatter には書かない。",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "本文冒頭の H1 見出しから導出される。frontmatter には書かない。"
    },
    "created_at": {
      "description": "起票日。YYYY-MM-DD または RFC3339。",
      "oneOf": [{ "type": "string", "format": "date" }, { "type": "string", "format": "date-time" }]
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "completed", "cancelled"]
    },
    "depends_on": {
      "description": "この work-item の完了前に完了が必要な work-item ID。一時的な関連や後続候補は含めない。",
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^wi-[0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "change_kind": {
      "type": "string",
      "enum": ["feature", "bugfix", "operations", "refactor", "docs", "tooling", "maintenance"]
    },
    "motivation": {
      "description": "根拠。なぜこの変更が必要か。",
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "description": "対象範囲。free-form (object / array / string)。",
      "anyOf": [{ "type": "object" }, { "type": "array" }, { "type": "string", "minLength": 1 }]
    },
    "out_of_scope": {
      "description": "範囲外。",
      "type": "array"
    },
    "plan": {
      "description": "中規模以上の work-item における実装前の技術方針、設計選択、未決定事項。",
      "type": "string",
      "minLength": 1
    },
    "tasks": {
      "description": "途中再開できる粒度の進捗チェックリスト。Markdown checkbox を含む文字列。",
      "type": "string",
      "minLength": 1,
      "pattern": "- \\[[ xX]\\] T[0-9]{3}"
    },
    "initial_context": {
      "description": "AI が作業開始時に読むべき最小文脈。SCL 要素、ADR、実装、テスト、読まない範囲を記録する。",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "features": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "scl": { "type": "object" },
        "decisions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "source": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "tests": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "stop_before_reading": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "affected_spec": {
      "description": "影響する SCL 規範要素への direct reference。",
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sclElementReference" }
    },
    "spec_impact": {
      "description": "SCL 非影響変更の例外宣言。",
      "type": "object",
      "required": ["kind", "reason"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "none" },
        "reason": { "type": "string", "minLength": 10 }
      }
    },
    "affected_guarantees": {
      "description": "影響する保証義務 (SCL assurance の文脈)。",
      "type": "array"
    },
    "verification": {
      "description": "検証コマンド / 手動手順のリスト。",
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "object",
            "required": ["cmd"],
            "properties": {
              "cmd": { "type": "string", "minLength": 1 },
              "in": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        ]
      }
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "risk_notes": {
      "type": "string",
      "minLength": 1
    },
    "target_state": {
      "description": "推奨形式。Refactor 系で「整合後の状態」を宣言する場合に使う。"
    },
    "completion": {
      "description": "完了または中止の判断記録。status が completed/cancelled になった時点で追記する。",
      "type": "object",
      "required": ["completed_at", "summary"],
      "properties": {
        "completed_at": {
          "oneOf": [
            { "type": "string", "format": "date" },
            { "type": "string", "format": "date-time" }
          ]
        },
        "summary": {
          "description": "意味上の差分の要約。",
          "type": "string",
          "minLength": 1
        },
        "verification": {
          "description": "検証結果。",
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              {
                "type": "object",
                "required": ["cmd"],
                "properties": {
                  "cmd": { "type": "string", "minLength": 1 },
                  "in": { "type": "string" },
                  "result": {}
                }
              }
            ]
          }
        },
        "evidence": {
          "description": "検証証跡。大容量ログやバイナリは埋め込まず、artifact 参照とハッシュを記録する。",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "kind", "result"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.-]*$"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "test",
                  "property_test",
                  "model_check",
                  "contract_test",
                  "mutation_test",
                  "static_analysis",
                  "scan",
                  "runtime_observation",
                  "manual_inspection",
                  "build",
                  "lint",
                  "typecheck",
                  "other"
                ]
              },
              "command": { "type": "string", "minLength": 1 },
              "procedure": { "type": "string", "minLength": 1 },
              "environment": { "type": "string", "minLength": 1 },
              "producer": {
                "type": "string",
                "enum": ["generator", "independent", "human", "ci", "local"]
              },
              "executed_at": {
                "oneOf": [
                  { "type": "string", "format": "date" },
                  { "type": "string", "format": "date-time" }
                ]
              },
              "target_revision": { "type": "string", "minLength": 1 },
              "result": {
                "anyOf": [
                  {
                    "type": "string",
                    "enum": ["passed", "failed", "not_run", "exception_approved"]
                  },
                  { "type": "string", "minLength": 1 }
                ]
              },
              "summary": { "type": "string", "minLength": 1 },
              "artifacts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["summary"],
                  "properties": {
                    "summary": { "type": "string", "minLength": 1 },
                    "path": { "type": "string", "minLength": 1 },
                    "uri": { "type": "string", "minLength": 1 },
                    "sha256": {
                      "type": "string",
                      "pattern": "^[a-fA-F0-9]{64}$"
                    },
                    "content_type": { "type": "string", "minLength": 1 },
                    "size_bytes": { "type": "integer", "minimum": 0 }
                  },
                  "anyOf": [{ "required": ["path"] }, { "required": ["uri"] }]
                }
              }
            },
            "anyOf": [
              { "required": ["command"] },
              { "required": ["procedure"] },
              { "required": ["artifacts"] }
            ]
          }
        },
        "affected_guarantees_state": {
          "description": "保証義務の状態。",
          "type": "array"
        },
        "remaining_guarantees_state": {
          "description": "保証義務の状態 (旧表記)。`affected_guarantees_state` を推奨。",
          "type": "array"
        },
        "residual_risk": {
          "description": "残リスク。",
          "type": "array"
        },
        "semantic_diff": {
          "description": "意味上の差分の詳細。"
        },
        "traceability": {
          "description": "仕様 ⇄ 実装 / テストへの対応関係。"
        },
        "human_decisions": {
          "description": "人間の判断。"
        },
        "approver_note": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "sclElementReference": {
      "oneOf": [
        {
          "type": "object",
          "required": ["context", "kind", "element"],
          "additionalProperties": false,
          "properties": {
            "context": { "type": "string", "minLength": 1 },
            "kind": {
              "enum": [
                "model",
                "interface",
                "state",
                "authorization_resource",
                "authorization_principal",
                "authorization_policy",
                "objective",
                "scenario",
                "flow"
              ]
            },
            "element": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "required": ["context", "kind", "standard", "requirement"],
          "additionalProperties": false,
          "properties": {
            "context": { "type": "string", "minLength": 1 },
            "kind": { "const": "standard_requirement" },
            "standard": { "type": "string", "minLength": 1 },
            "requirement": { "type": "string", "minLength": 1 }
          }
        }
      ]
    }
  }
}
